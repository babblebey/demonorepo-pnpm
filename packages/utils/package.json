{
  "name": "@demonorepo-pnpm/utils",
  "version": "1.0.0",
  "description": "Shared utility functions for the demonorepo-pnpm monorepo",
  "main": "index.js",
  "scripts": {
    "test": "node --test"
  },
  "keywords": ["utils", "monorepo"],
  "license": "MIT",
  "release": {
    "plugins": [
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/git",
        {
          "assets": ["CHANGELOG.md"],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
